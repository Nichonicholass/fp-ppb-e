rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own watchlist document
    match /watchlists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Each user can only read/write their own portfolio data
    match /users/{userId}/portfolio/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Each user can only read/write their own quiz reward claims
    match /users/{userId}/quizRewards/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /questions/{document} {
      allow read: if true;
      allow write: if false; // Use bin/seed_questions.dart to update
    }

    match /modules/{document} {
      allow read: if true;
      allow write: if false; // Use bin/seed_questions.dart to update
    }
  }
}
